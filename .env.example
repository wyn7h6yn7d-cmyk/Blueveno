# Supabase (required for auth, journal, profiles)
# Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (sb_publishable_…) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: billing / trials — see docs/BILLING.md
# AUTH_SECRET=
# BILLING_PLAN_TIER_OVERRIDE=

# Auth is email + password (Supabase). Add /auth/callback to Supabase Auth redirect URLs if you use email confirmation.
